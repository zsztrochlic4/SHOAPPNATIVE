{
  "expo": {
    "name": "StrengthHub",
    "slug": "strengthhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "strengthhub",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zaggy887.strengthhub",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.zaggy887.strengthhub",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-image-picker",
      "expo-status-bar",
      "expo-video",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#0A0A0B"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "backgroundColor": "#0A0A0B"
        }
      ]
    ]
  }
}
