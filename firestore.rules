rules_version = '2';

// StrengthHub — Firestore security rules.
//
// Data model (see src/store/cloudRepo.ts):
//   users/{uid}                    ← the user's singleton state document
//   users/{uid}/{collection}/{id}  ← one document per entry for each unbounded
//                                     log (sessions, weights, habits, meals,
//                                     activities, foodReviews, chat, coachThread,
//                                     notifications).
//
// A signed-in user can read and write ONLY their own tree under users/{uid};
// everything else is denied by default. That owner-only guarantee is what makes
// it safe to ship the (non-secret) Firebase web config in the app, and it scales
// to any number of users because access is scoped per-uid rather than globally.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      // The root singleton document.
      allow read, write: if isOwner();

      // Every per-user subcollection document (sessions, weights, …) inherits
      // the same owner-only rule at any depth. Includes the workout-backend
      // records: programs/{id} and workout_instances/{id}.
      match /{document=**} {
        allow read, write: if isOwner();
      }
    }

    // Global coach runtime config (config/coach: message limits, guardrail prompt).
    // Not per-user and not sensitive, but it does not need to be world-readable — the
    // coach is a signed-in feature — so it is readable by any authenticated user and
    // never client-writable (set from the console/admin only).
    // NOTE: the live project currently allows PUBLIC read here. Before deploying this
    // tightened rule, confirm nothing in the deployed client reads config/coach BEFORE
    // sign-in, or that pre-login read will start failing.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything outside a user's own tree.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
