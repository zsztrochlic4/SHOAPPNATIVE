rules_version = '2';

// StrengthHub — Firestore security rules.
//
// Data model (see src/store/cloudRepo.ts):
//   users/{uid}                    ← the user's singleton state document
//   users/{uid}/{collection}/{id}  ← one document per entry for each unbounded
//                                     log (sessions, weights, habits, meals,
//                                     activities, foodReviews, chat, coachThread,
//                                     notifications).
//
// A signed-in user can read and write ONLY their own tree under users/{uid};
// everything else is denied by default. That owner-only guarantee is what makes
// it safe to ship the (non-secret) Firebase web config in the app, and it scales
// to any number of users because access is scoped per-uid rather than globally.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      // The root singleton document.
      allow read, write: if isOwner();

      // Every per-user subcollection document (sessions, weights, …) inherits
      // the same owner-only rule at any depth.
      match /{document=**} {
        allow read, write: if isOwner();
      }
    }

    // Deny everything outside a user's own tree.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
