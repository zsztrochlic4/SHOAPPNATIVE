# StrengthHub Online — environment variables
#
# Copy to ".env" for local dev, or set these in your hosting provider
# (Vercel/Netlify project settings). NEVER commit a real key — this repo is
# public, and the key must only ever live in server-side environment variables.

# ── Server only (powers the Claude-backed coach messenger) ──────────────
# Read by the serverless function in /api/coach.ts. Without it, the coach
# falls back to the on-device rules engine so the demo still works.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional client override ────────────────────────────────────────────
# Where the browser sends coach messages. Defaults to /api/coach (same origin).
# Only set this if your function is hosted elsewhere.
# VITE_COACH_API=/api/coach

# ── Firebase web config (accounts + cloud data sync) ─────────────────────
# From Firebase console → Project settings → Your apps → Web app → firebaseConfig.
# These are NOT secrets (security is enforced by Firestore/Storage rules), so
# they're safe to commit. Copy this file to ".env" and fill them in. If they're
# blank the app runs in local demo mode with no login.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── App Check (abuse/attestation protection) ─────────────────────────────
# reCAPTCHA v3 SITE key (public) — from the Firebase console → App Check after
# registering the web app. The client uses it once App Check is enabled in the
# console; blank = App Check stays a safe no-op. See src/lib/appCheck.ts.
EXPO_PUBLIC_APPCHECK_RECAPTCHA_KEY=
# Optional debug token for local web development only (never set in production).
# EXPO_PUBLIC_APPCHECK_DEBUG_TOKEN=
